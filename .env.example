# App
APP_NAME=Forager
DEBUG=True

# Database
DATABASE_URL=postgresql+asyncpg://forager:forager@localhost:5432/forager_db
POSTGRES_USER=forager
POSTGRES_DB=forager_db
POSTGRES_PASSWORD=forager

# Redis
REDIS_URL=redis://redis:6379/0

# Auth — generate a real key for production: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OAuth — leave empty to disable
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# USDA FoodData Central — leave empty to disable nutrition lookups
USDA_API_KEY=

# LLM
OLLAMA_BASE_URL=http://localhost:11434

# URLs — override for production
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
